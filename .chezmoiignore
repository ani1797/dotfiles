# .chezmoiignore — files chezmoi skips depending on context
# https://www.chezmoi.io/reference/special-files/chezmoiignore/

# ── Repo-only files (never applied to home) ───────────────────────────────────
scripts
install.sh
README.md
.github

# ── Codespaces: skip all desktop/GUI configs ──────────────────────────────────
{{ if .codespaces }}
.config/hypr
.config/kitty
.config/mako
.config/quickshell
.config/systemd
.config/containers
{{ end }}

# ── Non-desktop Linux / Codespaces: skip desktop configs ─────────────────────
{{ if not .isDesktop }}
.config/hypr
.config/kitty
.config/mako
.config/quickshell
.config/systemd
{{ end }}
