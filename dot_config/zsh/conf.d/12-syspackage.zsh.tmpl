# 12-syspackage.zsh — OS-native system package manager aliases
# Generated by chezmoi — do not edit directly.
# Provides a generic interface: install, remove, search, update

{{ if eq .chezmoi.os "darwin" -}}
# ── macOS (Homebrew) ──────────────────────────────────────────────────────────
command -v brew &>/dev/null || return 0

alias install='brew install'
alias remove='brew uninstall'
alias search='brew search'
alias update='brew update && brew upgrade'

{{ else if eq .chezmoi.os "linux" -}}
{{-   $isArch := stat "/etc/arch-release" -}}
{{-   $isFedoraOstree := stat "/run/ostree-booted" -}}
{{-   $isDebian := stat "/etc/debian_version" -}}
{{-   $isFedora := stat "/etc/fedora-release" -}}
{{-   $isSuse := stat "/etc/SuSE-release" -}}
{{-   $isAlpine := stat "/etc/alpine-release" -}}

{{ if $isArch }}
# ── Arch Linux (paru + pacman) ────────────────────────────────────────────────
command -v paru &>/dev/null || return 0

alias install='paru -S --noconfirm'
alias remove='paru -Rns --noconfirm'
alias search='paru -Ss'
alias update='paru -Syu'

alias pacinstall='sudo pacman -S'
alias pacremove='sudo pacman -Rns'
alias pacsearch='sudo pacman -Ss'
alias pacupdate='sudo pacman -Syu'

{{ else if $isFedoraOstree }}
# ── Fedora Silverblue (rpm-ostree + flatpak) ──────────────────────────────────
install()  { echo "[rpm-ostree] Staging $*…"; rpm-ostree install "$@" && echo "Reboot to activate."; }
remove()   { echo "[rpm-ostree] Staging removal of $*…"; rpm-ostree remove "$@" && echo "Reboot to activate."; }
search()   { command -v dnf5 &>/dev/null && dnf5 search "$@" || dnf search "$@"; }
update()   { rpm-ostree upgrade && echo "Reboot to activate staged upgrade."; }

alias finstall='flatpak install --user flathub'
alias fremove='flatpak remove --user'
alias fsearch='flatpak search'
alias fupdate='flatpak update --user'

{{ else if $isDebian }}
# ── Debian / Ubuntu (apt) ─────────────────────────────────────────────────────
alias install='sudo apt install -y'
alias remove='sudo apt remove -y'
alias search='apt search'
alias update='sudo apt update && sudo apt upgrade -y'

{{ else if $isFedora }}
# ── Fedora (dnf) ──────────────────────────────────────────────────────────────
alias install='sudo dnf install -y'
alias remove='sudo dnf remove -y'
alias search='dnf search'
alias update='sudo dnf upgrade -y'

{{ else if $isSuse }}
# ── openSUSE (zypper) ────────────────────────────────────────────────────────
alias install='sudo zypper install -y'
alias remove='sudo zypper remove -y'
alias search='zypper search'
alias update='sudo zypper refresh && sudo zypper update -y'

{{ else if $isAlpine }}
# ── Alpine (apk) ─────────────────────────────────────────────────────────────
alias install='sudo apk add'
alias remove='sudo apk del'
alias search='apk search'
alias update='sudo apk update && sudo apk upgrade'

{{ end }}
{{ end }}
