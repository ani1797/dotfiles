# Global gitattributes — applied on top of each repo's .gitattributes.
# Managed by chezmoi.

# Auto-detect text files and normalise line endings to LF in the repo.
* text=auto eol=lf

# Shell / scripts — always LF, even on Windows checkouts.
*.sh    text eol=lf
*.bash  text eol=lf
*.zsh   text eol=lf
*.fish  text eol=lf

# Windows batch / PowerShell — keep CRLF.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Explicitly binary — never diff, never normalise.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.tgz   binary
*.7z    binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.mp3   binary
*.mp4   binary
*.mov   binary

# Lockfiles — checked in but uninteresting in diffs / not subject to merge.
package-lock.json   -diff merge=ours linguist-generated
pnpm-lock.yaml      -diff merge=ours linguist-generated
yarn.lock           -diff merge=ours linguist-generated
Cargo.lock          -diff
poetry.lock         -diff linguist-generated
uv.lock             -diff linguist-generated
