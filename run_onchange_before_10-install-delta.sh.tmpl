#!/bin/bash
# Installs delta — a syntax-highlighting pager for git diffs.
{{ template "install-helper" . }}

command -v delta &>/dev/null && exit 0

info "Installing delta…"

{{ if eq .chezmoi.os "darwin" -}}
pkg_install git-delta
{{ else if eq .chezmoi.os "linux" -}}
{{   if or (eq .chezmoi.osRelease.id "arch") (eq .chezmoi.osRelease.id "cachyos") (eq .chezmoi.osRelease.id "endeavouros") (eq .chezmoi.osRelease.id "manjaro") (eq .chezmoi.osRelease.id "garuda") -}}
pkg_install git-delta
{{   else -}}
if ! pkg_install git-delta 2>/dev/null; then
  if command -v cargo &>/dev/null; then
    info "Not in repos — falling back to cargo…"
    cargo install git-delta --locked
  else
    warn "delta: not in repos and cargo not found."
    warn "Install rustup first, then: cargo install git-delta --locked"
    exit 0
  fi
fi
{{   end -}}
{{ end -}}

success "delta installed."
