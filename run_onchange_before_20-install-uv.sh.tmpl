#!/bin/bash
# Installs uv — fast Python package manager.
{{ template "install-helper" . }}

command -v uv &>/dev/null && exit 0

info "Installing uv…"

{{ if eq .chezmoi.os "darwin" -}}
pkg_install uv
{{ else if eq .chezmoi.os "linux" -}}
{{   if or (eq .chezmoi.osRelease.id "arch") (eq .chezmoi.osRelease.id "cachyos") (eq .chezmoi.osRelease.id "endeavouros") (eq .chezmoi.osRelease.id "manjaro") (eq .chezmoi.osRelease.id "garuda") -}}
pkg_install uv
{{   else -}}
curl -LsSf https://astral.sh/uv/install.sh | sh
{{   end -}}
{{ end -}}

success "uv installed."
