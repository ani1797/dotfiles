# uv global configuration
# Managed by chezmoi — do not edit directly

prerelease = "allow"

# Named indexes — explicit so projects opt-in via [tool.uv.sources]
# Usage in pyproject.toml:
#   [tool.uv.sources]
#   torch = { index = "pytorch-cu130" }
#   torchvision = { index = "pytorch-cu130" }

# ── PyTorch ───────────────────────────────────────────────────────────────────

[[index]]
name = "pytorch-cpu"
url = "https://download.pytorch.org/whl/cpu"
explicit = true

[[index]]
name = "pytorch-cu126"
url = "https://download.pytorch.org/whl/cu126"
explicit = true

[[index]]
name = "pytorch-cu130"
url = "https://download.pytorch.org/whl/cu130"
explicit = true

# ── NVIDIA (RAPIDS, TensorRT, cuDF, cuPy, etc.) ──────────────────────────────

[[index]]
name = "nvidia"
url = "https://pypi.ngc.nvidia.com"
explicit = true

# ── Test PyPI (for pre-release / test uploads) ───────────────────────────────

[[index]]
name = "testpypi"
url = "https://test.pypi.org/simple"
explicit = true
{{ if env "PRODIGY_KEY" }}
# ── Prodigy (Explosion AI annotation tool — requires license) ────────────────

[[index]]
name = "prodigy"
url = "https://{{ env "PRODIGY_KEY" }}@download.prodi.gy"
explicit = true
{{ end }}
