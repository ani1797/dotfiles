# 12-syspackage.zsh — OS-native system package manager aliases
# Generated by chezmoi — do not edit directly.

{{ if eq .chezmoi.os "linux" -}}
{{-   $isArch := stat "/etc/arch-release" -}}
{{-   $isFedoraOstree := stat "/run/ostree-booted" -}}

{{ if $isArch }}
# ── Arch Linux (paru + pacman) ────────────────────────────────────────────────
#
# Two backends:
#   paru  — AUR + official repos (day-to-day installs, no sudo for AUR builds)
#   pacman — official repos only, always requires sudo

command -v paru &>/dev/null || return 0

# Generic interface (paru backend)
alias install='paru -S --noconfirm'
alias remove='paru -Rns --noconfirm'
alias search='paru -Ss'
alias update='paru -Syu'

# Explicit pacman backend
alias pacinstall='sudo pacman -S'
alias pacremove='sudo pacman -Rns'
alias pacsearch='sudo pacman -Ss'
alias pacupdate='sudo pacman -Syu'

{{ else if $isFedoraOstree }}
# ── Fedora Silverblue (rpm-ostree + flatpak) ──────────────────────────────────
#
# Two package layers:
#   rpm-ostree — staged, requires reboot to activate
#   flatpak    — immediate, sandboxed user-space apps

# Generic interface (rpm-ostree backend)
install()  { echo "[rpm-ostree] Staging $*…"; rpm-ostree install "$@" && echo "Reboot to activate."; }
remove()   { echo "[rpm-ostree] Staging removal of $*…"; rpm-ostree remove "$@" && echo "Reboot to activate."; }
search()   { command -v dnf5 &>/dev/null && dnf5 search "$@" || dnf search "$@"; }
update()   { rpm-ostree upgrade && echo "Reboot to activate staged upgrade."; }

# Flatpak shortcuts (immediate — no reboot needed)
alias finstall='flatpak install --user flathub'
alias fremove='flatpak remove --user'
alias fsearch='flatpak search'
alias fupdate='flatpak update --user'

{{ else }}
# ── Generic Linux (no recognised package manager) ─────────────────────────────
alias search='command -v apt &>/dev/null && apt search || command -v dnf &>/dev/null && dnf search || echo "No supported package manager found"'
{{ end }}
{{ end }}
