#!/bin/bash
# Installs eza — a modern replacement for ls.
{{ template "install-helper" . }}

command -v eza &>/dev/null && exit 0

info "Installing eza…"

{{ if eq .chezmoi.os "darwin" -}}
pkg_install eza
{{ else if eq .chezmoi.os "linux" -}}
{{   if or (eq .chezmoi.osRelease.id "arch") (eq .chezmoi.osRelease.id "cachyos") (eq .chezmoi.osRelease.id "endeavouros") (eq .chezmoi.osRelease.id "manjaro") (eq .chezmoi.osRelease.id "garuda") -}}
pkg_install eza
{{   else -}}
if ! pkg_install eza 2>/dev/null; then
  if command -v cargo &>/dev/null; then
    info "Not in repos — falling back to cargo…"
    cargo install eza --locked
  else
    warn "eza: not in repos and cargo not found."
    warn "Install rustup first, then: cargo install eza --locked"
    exit 0
  fi
fi
{{   end -}}
{{ end -}}

success "eza installed."
