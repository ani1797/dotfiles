{{- /* monitors.conf — machine-specific monitor configuration */ -}}
{{- /* chezmoi will prompt for these values on first init */ -}}
{{- $monitor := promptStringOnce . "monitor" "Primary monitor name (e.g. DP-1, HDMI-A-1, eDP-1)" -}}
{{- $resolution := promptStringOnce . "resolution" "Monitor resolution and refresh (e.g. 2560x1440@144)" -}}
{{- $scale := promptStringOnce . "scale" "Monitor scale factor (e.g. 1, 1.5, 2)" -}}

# monitors.conf — generated by chezmoi
# To reconfigure: chezmoi edit ~/.config/hypr/modules/monitors.conf

monitor = {{ $monitor }}, {{ $resolution }}, 0x0, {{ $scale }}

# Uncomment for multi-monitor:
# monitor = HDMI-A-1, 1920x1080@60, 2560x0, 1

# Fallback for any unknown monitor:
monitor = , preferred, auto, 1
