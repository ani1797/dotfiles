# .chezmoiignore — files chezmoi skips depending on context
# https://www.chezmoi.io/reference/special-files/chezmoiignore/

# ── Repo-only files (never applied to home) ───────────────────────────────────
install.sh
README.md
.github

# ── Non-Linux: skip Linux-specific configs ────────────────────────────────────
{{ if ne .chezmoi.os "linux" }}
.config/hypr
.config/mako
.config/quickshell
.config/systemd
.config/containers
{{ end }}

# ── Non-desktop: skip desktop configs ─────────────────────────────────────────
{{ if not .isDesktop }}
.config/hypr
.config/kitty
.config/mako
.config/quickshell
.config/systemd
{{ end }}

# ── Codespaces: skip GUI and container configs ────────────────────────────────
{{ if .codespaces }}
.config/kitty
.config/containers
{{ end }}
