{{- $codespaces := env "CODESPACES" | not | not -}}
{{- $isDesktop := and (not $codespaces) (eq .chezmoi.os "linux") -}}

{{- $name := promptStringOnce . "name" "Full name" -}}
{{- $email := promptStringOnce . "email" "Email address" -}}
{{- $hostname := promptStringOnce . "hostname" "Machine hostname" -}}

{{- $monitor := "" -}}
{{- $resolution := "" -}}
{{- $scale := "" -}}
{{- if $isDesktop -}}
{{-   $monitor := promptStringOnce . "monitor" "Primary monitor name (e.g. DP-1, eDP-1)" -}}
{{-   $resolution := promptStringOnce . "resolution" "Monitor resolution@refresh (e.g. 2560x1440@144)" -}}
{{-   $scale := promptStringOnce . "scale" "Monitor scale (e.g. 1, 1.5, 2)" -}}
{{- end -}}

[data]
  name       = {{ $name | quote }}
  email      = {{ $email | quote }}
  hostname   = {{ $hostname | quote }}
  codespaces = {{ $codespaces }}
  isDesktop  = {{ $isDesktop }}
  monitor    = {{ $monitor | quote }}
  resolution = {{ $resolution | quote }}
  scale      = {{ $scale | quote }}
